# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# design-reference: local-only Claude Design exports (single-file HTML with
# base64-inlined assets, ~53MB) + screenshots. Working source material used to
# build pages 1:1; the production build/runtime never imports them. Kept out of
# Git to avoid permanent clone bloat. Regenerate locally, don't commit.
/design-reference/

# typescript
*.tsbuildinfo
next-env.d.ts
